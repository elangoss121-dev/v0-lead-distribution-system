// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  providers         ProviderAssignment[]
  leads             Lead[]
  allocationPointers AllocationPointer[]

  @@map("service")
}

model Provider {
  id                  String   @id @default(uuid())
  name                String
  email               String   @unique
  phone               String?
  monthly_quota_limit Int      @default(10)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  assignments    ProviderAssignment[]
  quotaLogs      ProviderQuotaLog[]
  allocationPtrs AllocationPointer[]
  assignedLeads  AssignedLead[]

  @@map("provider")
}

model ProviderAssignment {
  id          String   @id @default(uuid())
  service_id  String
  provider_id String
  is_mandatory Boolean  @default(false)
  created_at  DateTime @default(now())

  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([service_id, provider_id])
  @@map("provider_assignment")
}

model Lead {
  id         String   @id @default(uuid())
  service_id String
  phone      String
  email      String?
  name       String?
  created_at DateTime @default(now())

  service       Service       @relation(fields: [service_id], references: [id], onDelete: Cascade)
  assignedLeads AssignedLead[]

  @@unique([phone, service_id])
  @@map("lead")
}

model ProviderQuotaLog {
  id                    String   @id @default(uuid())
  provider_id           String
  leads_assigned_this_month Int @default(0)
  month_start_date      DateTime
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  provider Provider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, month_start_date])
  @@map("provider_quota_log")
}

model AllocationPointer {
  id             String   @id @default(uuid())
  service_id     String
  provider_id    String
  current_position Int    @default(0)
  updated_at     DateTime @updatedAt

  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([service_id, provider_id])
  @@map("allocation_pointer")
}

model WebhookIdempotencyKey {
  id              String   @id @default(uuid())
  idempotency_key String   @unique
  timestamp       DateTime @default(now())

  @@map("webhook_idempotency_key")
}

model AssignedLead {
  id         String   @id @default(uuid())
  lead_id    String
  provider_id String
  assigned_at DateTime @default(now())

  lead     Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([lead_id, provider_id])
  @@map("assigned_lead")
}
